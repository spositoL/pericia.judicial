# ========================================
# GA4 Integration Configuration
# ========================================
# Copie este arquivo para .env e preencha os valores

# ID da propriedade Google Analytics 4
GA4_PROPERTY_ID=471852848

# Caminho para o arquivo JSON de credenciais do Google Cloud
# Baixe de: Google Cloud Console > Service Accounts > Create Key (JSON)
GOOGLE_APPLICATION_CREDENTIALS=./ga4-credentials.json

# Intervalo de sincronização em horas (opcional)
SYNC_INTERVAL_HOURS=24

# ========================================
# Instruções
# ========================================
# 1. Renomeie este arquivo para .env (remova .example)
# 2. Crie um Service Account no Google Cloud (veja setup-guide.md)
# 3. Download das credenciais em JSON
# 4. Coloque o arquivo JSON na raiz do projeto
# 5. Atualize o caminho em GOOGLE_APPLICATION_CREDENTIALS
# 6. Execute: npm install
# 7. Execute: node ga4-sync.js
# 8. Abra ga4-dashboard.html no navegador (ou VS Code Preview)
